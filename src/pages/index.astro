---
import Layout from "../layouts/Layout.astro";
import HomeContent from "../components/HomeContent.astro";
import { translations } from "../i18n/translations";

const lang = "es";
const t = translations[lang];

const title =
  lang === "es"
    ? "Dot Studio | Desarrollo Web Profesional"
    : "Dot Studio | Professional Web Development";
const description =
  lang === "es"
    ? "Transformamos ideas en experiencias digitales. Creamos landing pages, sitios web y e-commerce a medida que impulsan tu negocio."
    : "We transform ideas into digital experiences. We create custom landing pages, websites and e-commerce that drive your business.";
---

<Layout title={title} description={description} lang={lang}>
  <HomeContent t={t} lang={lang} />
</Layout>
