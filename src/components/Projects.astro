      en: "Chilean collective financing platform that enables online investment in fixed real estate returns through blockchain-tokenized assets. Responsible for the public landing, marketplace, and investor dashboard with real-time portfolio monitoring, KYC, digital signing, and AI-powered risk scoring.",
    },
    technologies: [
      "Meteor.js",
      "Python",
      "Gatsby",
      "Tailwind CSS",
      "MongoDB",
      "Blockchain",
      "AI",
    ],
    url: "https://tokenit.cl",
  },
  {
    name: "Thender",
    image: "/projects/thender.png",
    category: "Social Platform",
    description: {
      es: "Una plataforma de citas y comunidades de vanguardia diseñada para que grupos específicos se conecten, compartan y crezcan juntos. Construida con capacidades en tiempo real, autenticación segura y una experiencia de usuario fluida centrada en conexiones significativas.",
      en: "A cutting-edge dating and community platform designed for niche groups to connect, share, and grow together. Built with real-time capabilities, secure authentication, and a sleek user experience focusing on meaningful connections.",
    },
    technologies: ["Next.js", "Convex", "Clerk", "Tailwind CSS", "TypeScript"],
    url: "https://thender.vercel.app/",
  },
  {
    name: "Zatobox",
    image: "/projects/zatobox.png",
    category: "Startup POS",
    description: {
      es: "ZatoBox es un sistema POS modular y open-source para PyMEs y emprendedores. Incluye gestión de inventario en la nube, catálogos online con ZatoLink, conexión de pagos mediante ZatoConnect y próximos módulos como Smart Inventory y automatización. Diseñado para ser simple, escalable y adaptable a cualquier negocio.",
      en: "ZatoBox is a modular, open-source POS system for SMEs and entrepreneurs. It includes cloud-based inventory management, online catalogs with ZatoLink, payment connection through ZatoConnect, and upcoming modules like Smart Inventory and automation. Designed to be simple, scalable, and adaptable to any business.",
    },
    technologies: [
      "React.js",
      "Zustand",
      "Supabase",
      "Next.js",
      "Python",
      "PostgreSQL",
      "Docker",
      "Vercel",
      "Tailwind CSS",
      "TypeScript",
    ],
    url: "https://www.zatobox.io/",
  },
  {
    name: "Liz",
    image: "/projects/liz.png",
    category: "Landing Page",
    description: {
      es: "Liz es una aplicación web moderna y responsive diseñada para entusiastas del anime y manga. Permite descubrir contenido en tendencia, buscar con filtros avanzados, trackear el progreso de visualización/lectura y gestionar listas personalizadas. Construida con Vue 3, Supabase y la API de AniList.",
      en: "Liz is a modern, responsive web application designed for anime and manga enthusiasts. It allows users to discover trending content, search with advanced filters, track their watching/reading progress, and manage custom lists. Built with Vue 3, Supabase, and the AniList API.",
    },
    technologies: [
      "Vue.js",
      "TailwindCSS",
      "Pinia",
      "Anilist API",
      "Supabase",
      "Vite",
    ],
    url: "https://liz-beth.vercel.app/",
  },
];

const moreProjects = [
  {
    name: "Las Taurinas",
    image: "/projects/lastaurinas.png",
    category: "E-commerce",
    description: {
      es: "Las Taurinas es un e-commerce moderno construido en Empretienda, con integración de envíos Andreani, estilos CSS3 personalizados, y pagos seguros mediante Mercado Pago y transferencias bancarias. Enfocado en brindar una experiencia UX/UI fluida con un diseño totalmente responsivo.",
      en: "Las Taurinas is a modern e-commerce built on Empretienda, featuring Andreani shipping integration, custom CSS3 styling, and secure payments via Mercado Pago and bank transfers. Focused on providing a seamless UX/UI experience with a fully responsive design.",
    },
    technologies: [
      "Empretienda",
      "Andreani",
      "CSS3",
      "Mercado Pago",
      "UX/UI",
      "Responsive Design",
    ],
    url: "https://lastaurinas.empretienda.com.ar/",
  },
  {
    name: "Consentido Cognitivo",
    image: "/projects/consentido.png",
    category: "Web Platform",
    description: {
      es: "Sitio web informativo y accesible sobre estimulación neurocognitiva para adultos mayores, con recursos descargables y talleres cognitivos enfocados en el envejecimiento activo.",
      en: "Informational and accessible website for neurocognitive stimulation for older adults, featuring downloadable resources and cognitive workshops focused on active aging.",
    },
    url: "https://www.consentidocognitivo.site/",
    technologies: ["UX Design", "Neurocognitive Stimulation", "Active Aging"],
  },
  {
    name: "Dot Studio",
    image: "/projects/dot-studio.png",
    category: "Agency",
    description: {
      es: "En Dot Studio, no solo construimos sitios web; creamos ecosistemas digitales que impulsan el crecimiento. Nos especializamos en transformar ideas complejas en experiencias web fluidas, responsivas y de alta conversión.",
      en: "At Dot Studio, we don't just build websites; we create digital ecosystems that drive growth. We specialize in transforming complex ideas into seamless, responsive, and high-converting web experiences.",
    },
    technologies: ["Next.js", "UI/UX", "SEO", "E-commerce"],
    url: "https://dot-studio.site",
  },
  {
    name: "Gym Master",
    image: "/projects/gym-master.jpg",
    category: "Fitness",
    description: {
      es: "Gym Master es un sistema integral de gestión de gimnasios desarrollado por Dragon Pyramid, diseñado para automatizar tareas administrativas, mejorar la interacción con los miembros y proporcionar herramientas inteligentes para rutinas personalizadas y planes de nutrición.",
      en: "Gym Master is a comprehensive gym management system built by Dragon Pyramid, designed to automate administrative tasks, enhance member engagement, and provide intelligent tools for personalized routines and nutrition plans.",
    },
    technologies: [
      "React.js",
      "Supabase",
      "Next.js",
      "Tailwind CSS",
      "Python",
      "PostgreSQL",
      "Zustand",
    ],
    url: "https://gym-master-new.vercel.app/",
  },
];

const showMore = lang === "es" ? "Ver más proyectos" : "Show more projects";
const showLess = lang === "es" ? "Ver menos" : "Show less";
---

<section id="projects" class="projects">
  <div class="container">
    <div class="section-header" data-animate>
      <h2 class="section-title">{t.projects.title}</h2>
      <p class="section-subtitle">{t.projects.subtitle}</p>
    </div>

    <div class="projects-grid">
      {
        featuredProjects.map((project, index) => (
          <article class="project-card" data-animate data-delay={index * 150}>
            <div class="project-image">
              <img src={project.image} alt={project.name} loading="lazy" />
              <div class="project-overlay" />
            </div>
            <div class="project-info">
              <span class="project-category">{project.category}</span>
              <h3 class="project-name">{project.name}</h3>
              {project.description && (
                <p class="project-description">{project.description[lang]}</p>
              )}
              {project.technologies && (
                <div class="project-technologies">
                  {project.technologies.slice(0, 4).map((tech) => (
                    <span class="tech-tag">{tech}</span>
                  ))}
                  {project.technologies.length > 4 && (
                    <span class="tech-tag more">
                      +{project.technologies.length - 4}
                    </span>
                  )}
                </div>
              )}
              {project.url && (
                <a
                  href={project.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="project-link"
                >
                  <ExternalLink size={16} strokeWidth={2} />
                  <span>{lang === "es" ? "Ver proyecto" : "View project"}</span>
                </a>
              )}
            </div>
          </article>
        ))
      }
    </div>

    <div class="more-projects-wrapper">
      <div class="more-projects" id="more-projects">
        {
          moreProjects.map((project) => (
            <article class="project-card small">
              <div class="project-image">
                <img src={project.image} alt={project.name} loading="lazy" />
                <div class="project-overlay" />
              </div>
              <div class="project-info">
                <span class="project-category">{project.category}</span>
                <h3 class="project-name">{project.name}</h3>
                {project.description && (
                  <p class="project-description">{project.description[lang]}</p>
                )}
                {project.technologies && (
                  <div class="project-technologies">
                    {project.technologies.slice(0, 3).map((tech) => (
                      <span class="tech-tag">{tech}</span>
                    ))}
                    {project.technologies.length > 3 && (
                      <span class="tech-tag more">
                        +{project.technologies.length - 3}
                      </span>
                    )}
                  </div>
                )}
                {project.url && (
                  <a
                    href={project.url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="project-link"
                  >
                    <ExternalLink size={14} strokeWidth={2} />
                    <span>
                      {lang === "es" ? "Ver proyecto" : "View project"}
                    </span>
                  </a>
                )}
              </div>
            </article>
          ))
        }
      </div>
    </div>

    <div class="show-more-wrapper">
      <button
        class="show-more-btn"
        id="show-more-btn"
        data-show-text={showMore}
        data-hide-text={showLess}
      >
        <span class="btn-text">{showMore}</span>
        <ChevronDown size={18} strokeWidth={2} class="icon-down" />
        <ChevronUp size={18} strokeWidth={2} class="icon-up" />
      </button>
    </div>
  </div>
</section>

<style>
  .projects {
    padding: 6rem 2rem;
    background: #fafafa;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .section-header {
    text-align: center;
    margin-bottom: 4rem;
    opacity: 0;
    transform: translateY(30px);
    transition: all 0.6s ease;
  }

  .section-header.visible {
    opacity: 1;
    transform: translateY(0);
  }

  .section-title {
    font-size: 2.5rem;
    font-weight: 700;
    color: #1a1a1a;
    margin-bottom: 1rem;
    letter-spacing: -0.02em;
  }

  .section-subtitle {
    font-size: 1.1rem;
    color: var(--color-dot-shadow);
  }

  .projects-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2rem;
  }

  .project-card {
    position: relative;
    border-radius: 16px;
    overflow: hidden;
    background: white;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.06);
    transition: all 0.4s ease;
    opacity: 0;
    transform: translateY(50px);
  }

  .project-card.visible {
    opacity: 1;
    transform: translateY(0);
  }

  .more-projects .project-card {
    opacity: 1;
    transform: translateY(0);
  }

  .project-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.1);
  }

  .more-projects .project-card:hover {
    transform: translateY(-8px);
  }

  .project-card:hover .project-overlay {
    opacity: 1;
  }

  .project-card:hover .project-image img {
    transform: scale(1.05);
  }

  .project-image {
    position: relative;
    aspect-ratio: 16 / 10;
    overflow: hidden;
  }

  .project-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s ease;
  }

  .project-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0, 0, 0, 0.6), transparent);
    opacity: 0;
    transition: opacity 0.4s ease;
  }

  .project-info {
    padding: 1.5rem;
  }

  .project-category {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-dot-purple-700);
    background: var(--color-dot-purple-50);
    padding: 0.35rem 0.75rem;
    border-radius: 4px;
    margin-bottom: 0.75rem;
  }

  .project-name {
    font-size: 1.25rem;
    font-weight: 600;
    color: #1a1a1a;
  }

  .project-description {
    font-size: 0.9rem;
    color: var(--color-dot-shadow);
    line-height: 1.6;
    margin-top: 0.75rem;
  }

  .project-card.small .project-description {
    font-size: 0.85rem;
  }

  .project-technologies {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 1rem;
  }

  .tech-tag {
    font-size: 0.7rem;
    font-weight: 500;
    color: var(--color-dot-green-900);
    background: var(--color-dot-green-100);
    padding: 0.25rem 0.6rem;
    border-radius: 100px;
  }

  .tech-tag.more {
    background: rgba(0, 0, 0, 0.08);
    color: var(--color-dot-shadow);
  }

  .project-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    margin-top: 1rem;
    padding: 0.5rem 1rem;
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--color-dot-green-900);
    background: var(--color-dot-green-100);
    border-radius: 8px;
    transition: all 0.3s ease;
  }

  .project-link:hover {
    background: var(--color-dot-green-300);
    transform: translateX(4px);
  }

  .project-card.small .project-link {
    font-size: 0.8rem;
    padding: 0.4rem 0.8rem;
  }

  .more-projects-wrapper {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.6s ease;
  }

  .more-projects-wrapper.expanded {
    max-height: 4000px;
  }

  .more-projects {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    padding-top: 2rem;
  }

  .project-card.small .project-info {
    padding: 1.25rem;
  }

  .project-card.small .project-name {
    font-size: 1.1rem;
  }

  .show-more-wrapper {
    display: flex;
    justify-content: center;
    margin-top: 3rem;
  }

  .show-more-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 1rem 2rem;
    font-size: 0.95rem;
    font-weight: 600;
    font-family: inherit;
    color: #1a1a1a;
    background: white;
    border: 1px solid rgba(0, 0, 0, 0.12);
    border-radius: 100px;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .show-more-btn:hover {
    border-color: var(--color-dot-green-500);
    background: var(--color-dot-green-50);
  }

  .show-more-btn .icon-up {
    display: none;
  }

  .show-more-btn.expanded .icon-down {
    display: none;
  }

  .show-more-btn.expanded .icon-up {
    display: block;
  }

  @media (max-width: 900px) {
    .more-projects {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .projects {
      padding: 4rem 1.5rem;
    }

    .projects-grid {
      grid-template-columns: 1fr;
    }

    .more-projects {
      grid-template-columns: 1fr;
    }

    .section-title {
      font-size: 2rem;
    }
  }
</style>

<script>
  const animateElements = document.querySelectorAll("#projects [data-animate]");

  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const delay = entry.target.getAttribute("data-delay") || 0;
          setTimeout(
            () => {
              entry.target.classList.add("visible");
            },
            parseInt(delay as string),
          );
          observer.unobserve(entry.target);
        }
      });
    },
    {
      threshold: 0.1,
      rootMargin: "0px 0px -50px 0px",
    },
  );

  animateElements.forEach((el) => observer.observe(el));

  const showMoreBtn = document.getElementById("show-more-btn");
  const moreProjectsWrapper = document.querySelector(".more-projects-wrapper");
  const btnText = showMoreBtn?.querySelector(".btn-text");

  showMoreBtn?.addEventListener("click", () => {
    const isExpanded = moreProjectsWrapper?.classList.toggle("expanded");
    showMoreBtn.classList.toggle("expanded");

    if (btnText && showMoreBtn) {
      const showText = showMoreBtn.getAttribute("data-show-text") || "";
      const hideText = showMoreBtn.getAttribute("data-hide-text") || "";
      btnText.textContent = isExpanded ? hideText : showText;
    }
  });
</script>
