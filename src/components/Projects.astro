---
import type { Translations } from "../i18n/translations";
import { ChevronDown, ChevronUp, ExternalLink } from "lucide-astro";

interface Props {
  t: Translations;
  lang: "es" | "en";
}

const { t, lang } = Astro.props;

const featuredProjects = [
  {
    name: "Tokenit",
    image: "/projects/tokenit.png",
    category: "Fintech & Web3",
